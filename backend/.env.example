# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentbreaker

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET

# CORS
CORS_ORIGINS=["http://localhost:5173","https://app.agentbreaker.com"]

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Detection
RATE_LIMIT_PER_MINUTE=100
DEFAULT_KILL_THRESHOLD=75
DEFAULT_CARBON_REGION=us-east
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMULATOR_ENABLED=false

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# App URLs
APP_URL=https://app.agentbreaker.com
API_URL=https://api.agentbreaker.com

# Google AI (for playground simulator)
GOOGLE_API_KEY=
